# ===========================================
# Inventory Masjid - .gitignore
# ===========================================

# ----- Laravel (src/) -----
src/vendor/
src/node_modules/
src/public/hot
src/public/storage
src/storage/*.key
src/storage/app/*
!src/storage/app/.gitignore
src/storage/framework/cache/*
!src/storage/framework/cache/.gitignore
src/storage/framework/sessions/*
!src/storage/framework/sessions/.gitignore
src/storage/framework/testing/*
!src/storage/framework/testing/.gitignore
src/storage/framework/views/*
!src/storage/framework/views/.gitignore
src/storage/logs/*
!src/storage/logs/.gitignore
src/bootstrap/cache/*
!src/bootstrap/cache/.gitignore

# ----- Environment files -----
.env
src/.env
src/.env.backup
src/.env.production
src/.env.local
src/.env.*.local
# Keep example
!src/.env.example

# ----- Composer lock (optional - some prefer to commit) -----
src/composer.lock

# ----- Testing -----
src/.phpunit.result.cache
src/.phpunit.cache
src/phpunit.xml
.phpunit.result.cache
.phpunit.cache

# ----- IDE and editor files -----
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.sublime-project
*.sublime-workspace

# ----- PHP -----
*.log
composer.phar

# ----- NPM/Yarn -----
npm-debug.log
yarn-error.log

# ----- Laravel Mix/Vite -----
src/public/build/
src/public/hot/
src/public/css/
src/public/js/
src/public/mix-manifest.json

# ----- Docker -----
docker-compose.override.yml

# ----- Backup files -----
*.bak
*.backup
*.sql
*.gz
*.sqlite

# ----- Misc -----
*.cache
*.tmp
.sass-cache/
coverage/
.nyc_output/
